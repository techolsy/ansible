services:
  glance:
    container_name: glance
    image: glanceapp/glance:{{ glance_version }}
    restart: unless-stopped
    volumes:
      - ./config:/app/config
      - ./assets:/app/assets
      - /etc/localtime:/etc/localtime:ro
      - {{ glance_certificate }}
    ports:
      - 8080:8080
    env_file: .env
